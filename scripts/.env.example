### Identity Registry - Deployment Environment
# Copy this file to .env and fill in values.
# Example to load for a session: set -a; source scripts/.env.example; set +a

# ===== RPC / VERIFICATION =====
# RPC endpoint used by forge when broadcasting
RPC_URL=

# Etherscan API key for contract verification (required if using --verify)
ETHERSCAN_API_KEY=

# ===== CONFIG-DRIVEN DEPLOYMENT =====
# Path to JSON config (see scripts/example_config.json).
DEPLOY_CONFIG=

# ===== DEPLOYMENT =====
# Private key of the deployer account (pays gas fees and becomes initial owner)
PRIVATE_KEY=

# NOTE: The deployer will be the initial owner of all contracts.
# For production, transfer ownership to a multisig after deployment.
